<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDF5F5"
    android:padding="0dp"
    android:layout_margin="0dp">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_uptm_gradient"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white"
        app:title="Make a Booking"
        app:titleTextColor="@color/white"
        app:titleCentered="false"
        android:layout_margin="0dp"
        android:paddingHorizontal="0dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="0dp"
        android:layout_margin="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. TRIP TYPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Type"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgTripType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbFixed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fixed Trip"
                    android:checked="true"
                    android:textColor="#1A1A1A"/>

                <RadioButton
                    android:id="@+id/rbEvent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Event Trip"
                    android:textColor="#1A1A1A"/>

            </RadioGroup>

            <!-- 2. FIXED TRIP DETAILS -->
            <LinearLayout
                android:id="@+id/layoutFixed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Route"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/rgFixedDestination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rbUPTMtoSiswa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPTM → Siswa (6.4 km)"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp"/>

                    <RadioButton
                        android:id="@+id/rbUPTMtoSiswi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPTM → Siswi (1.5 km)"
                        android:checked="true"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp"/>

                    <RadioButton
                        android:id="@+id/rbSiswatoUPTM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Siswa → UPTM (6.4 km)"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp"/>

                    <RadioButton
                        android:id="@+id/rbSiswitoUPTM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Siswi → UPTM (1.5 km)"
                        android:textColor="#1A1A1A"/>

                </RadioGroup>

                <!-- Departure Date & Time -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Departure"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnSelectDate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Select Date"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#0033A0"
                        android:textColor="@color/white"/>

                    <Button
                        android:id="@+id/btnSelectTime"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Select Time"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#0033A0"
                        android:textColor="@color/white"/>

                </LinearLayout>

            </LinearLayout>

            <!-- 3. EVENT TRIP DETAILS (Return slots sentiasa kelihatan, tiada toggle) -->
            <LinearLayout
                android:id="@+id/layoutEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <!-- Event Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@color/white">

                        <TextView
                            android:id="@+id/tvEventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Event Title"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvEventLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="#4A4A4A"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/tvEventDateTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Date and Time"
                            android:textColor="#4A4A4A"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Departure Time Slots -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Departure Time"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutTimeSlots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/tvTimeSlotsError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No available time slots"
                    android:textColor="#E31B23"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="16dp"/>

                <!-- Return Time Slots (Optional - sentiasa kelihatan, tiada toggle) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Return Time (Optional)"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutReturnTimeSlots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"/>

                <LinearLayout
                    android:id="@+id/layoutReturnTimeSlotsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:id="@+id/tvReturnTimeSlotsError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No available return time slots"
                    android:textColor="#E31B23"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="16dp"/>

            </LinearLayout>

            <!-- 4. RETURN DATE TIME (untuk Fixed Trip sahaja) -->
            <LinearLayout
                android:id="@+id/layoutReturnDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Return Date and Time"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSelectReturnDate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Select Date"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#E31B23"
                        android:textColor="@color/white"/>

                    <Button
                        android:id="@+id/btnSelectReturnTime"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Select Time"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#E31B23"
                        android:textColor="@color/white"/>

                </LinearLayout>

            </LinearLayout>

            <!-- 5. SELECT VEHICLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Vehicle"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerVehicle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_border"
                android:layout_marginBottom="16dp"
                android:popupBackground="@drawable/spinner_dropdown_bg"
                android:spinnerMode="dropdown"/>

            <!-- 6. SELECT SEATS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectSeats"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="SELECT SEATS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="24dp"
                android:backgroundTint="#0033A0"
                android:layout_marginBottom="16dp"/>

            <!-- 7. PRICE DETAILS -->
            <LinearLayout
                android:id="@+id/layoutPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/border_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price Details"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Seats Info -->
                <LinearLayout
                    android:id="@+id/layoutSeatsInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Selected Seats"
                        android:textColor="#4A4A4A"/>

                    <TextView
                        android:id="@+id/tvSeatsInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#4A4A4A"/>

                </LinearLayout>

                <!-- Departure Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Departure"
                        android:textColor="#4A4A4A"/>

                    <TextView
                        android:id="@+id/tvDepartureInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#4A4A4A"/>

                </LinearLayout>

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Distance"
                        android:textColor="#4A4A4A"/>

                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 km"
                        android:textColor="#4A4A4A"/>

                </LinearLayout>

                <!-- One Way Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="One Way"
                        android:textColor="#4A4A4A"/>

                    <TextView
                        android:id="@+id/tvOneWayPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0.00"
                        android:textColor="#4A4A4A"/>

                </LinearLayout>

                <!-- Return Section -->
                <LinearLayout
                    android:id="@+id/layoutReturnSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginVertical="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Return Trip"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Return Date and Time"
                            android:textColor="#4A4A4A"/>

                        <TextView
                            android:id="@+id/tvReturnInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#4A4A4A"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Return Price (20% off)"
                            android:textColor="#4A4A4A"/>

                        <TextView
                            android:id="@+id/tvReturnPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM 0.00"
                            android:textColor="#4A4A4A"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvTotalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0.00"
                        android:textColor="#E31B23"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- 8. BOOK NOW BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBookNow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="BOOK NOW"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                android:backgroundTint="#0033A0"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>