<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVehicle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: Vehicle Image -->
        <ImageView
            android:id="@+id/ivVehicleIcon"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_bus"
            android:background="#F0F0F0"/>

        <!-- Row 2: Vehicle Name + Toggle Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <!-- ✅ FIX 1: Vehicle Name - Tukar warna hitam pekat -->
            <TextView
                android:id="@+id/tvVehicleName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UPTM"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Toggle Switch for Active/Inactive -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text=""
                android:thumbTint="@color/white"
                app:trackTint="#E0E0E0"
                app:thumbTint="#FFFFFF"
                app:trackColor="@color/uptm_blue"/>

        </LinearLayout>

        <!-- Row 3: Plate Number + Type Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <!-- ✅ FIX 2: Plate Number - Tukar warna kelabu gelap -->
            <TextView
                android:id="@+id/tvPlateNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="wr5678q"
                android:textColor="#4A4A4A"
                android:textSize="12sp"/>

            <!-- ✅ FIX 3: Type Badge - Tukar background biru gelap, text putih -->
            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:text="Bus"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/badge_rounded_blue"/>

        </LinearLayout>

        <!-- Row 4: Capacity & Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- ✅ FIX 4: Capacity - Tukar warna kelabu gelap -->
            <TextView
                android:id="@+id/tvCapacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="30 seats"
                android:textColor="#4A4A4A"
                android:textSize="12sp"/>

            <!-- ✅ FIX 5: Price - Kekal merah pekat -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 1.00/km"
                android:textColor="#E31B23"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Row 5: Action Buttons (Edit & Delete) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <!-- ✅ FIX 6: Edit Button - Tukar text color biru gelap -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="20dp"
                android:text="EDIT"
                android:textColor="#0033A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#E3F2FD"
                app:cornerRadius="18dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <!-- ✅ FIX 7: Delete Button - Tukar text color merah gelap -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="20dp"
                android:text="DELETE"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#FFEBEE"
                app:cornerRadius="18dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>