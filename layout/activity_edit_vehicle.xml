<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF5F5"
    android:fitsSystemWindows="true">

    <!-- Toolbar dengan back button dan title -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_uptm_gradient"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white"
        app:title="Edit Vehicle"
        app:titleTextColor="@color/white"
        app:titleCentered="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Vehicle Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vehicle Type"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgVehicleType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbBus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bus"
                    android:textColor="#333333"/>

                <RadioButton
                    android:id="@+id/rbCar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Car"
                    android:textColor="#333333"/>

            </RadioGroup>

            <!-- Brand -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etBrand"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g., Toyota, Scania"
                android:textColor="@color/black"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Plate Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plate Number"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etPlateNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g., ABC 1234"
                android:textColor="@color/black"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Seat Capacity & Price Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seat Capacity"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etSeatCapacity"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 30"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="16dp"
                        android:inputType="number"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price/km (RM)"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etPricePerKm"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 2.50"
                        android:background="@drawable/edittext_border"
                        android:textColor="@color/black"
                        android:paddingHorizontal="16dp"
                        android:inputType="numberDecimal"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Image URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Image URL"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etImageUrl"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="https://example.com/vehicle-image.jpg"
                android:textColor="@color/black"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Optional - leave empty for default image)"
                android:textSize="10sp"
                android:textColor="#999999"
                android:layout_marginBottom="16dp"/>

            <!-- Seat Layout Info -->
            <TextView
                android:id="@+id/tvSeatLayoutInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="* Seat layout: Auto-generated based on capacity"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:padding="8dp"
                android:background="#F0F0F0"
                android:gravity="center"/>

            <!-- Update Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateVehicle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="UPDATE VEHICLE"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                android:backgroundTint="#0033A0"
                android:layout_marginBottom="16dp"/>

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteVehicle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="DELETE VEHICLE"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                android:backgroundTint="#E31B23"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>