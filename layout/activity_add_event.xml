<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF5F5">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_uptm_gradient"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white"
        app:title="Add Event"
        app:titleTextColor="@color/white"
        app:titleCentered="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Event title"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Event location"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnSelectDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#0033A0"
                android:text="Select date"
                android:textColor="@color/white"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Start Time & End Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Time"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <Button
                        android:id="@+id/btnSelectTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#0033A0"
                        android:text="Select Time"
                        android:textColor="@color/white"
                        android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="End Time"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <Button
                        android:id="@+id/btnSelectEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#0033A0"
                        android:text="Select Time"
                        android:textColor="@color/white"
                        android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Event description"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:gravity="top"
                android:background="@drawable/edittext_border"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:layout_marginBottom="24dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="16dp" />

            <!-- Time Slot Settings Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Time Slot Settings"
                android:textColor="#0033A0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Departure Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Departure Slots (Before Event)"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hours Before"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etDepartureHoursBefore"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 3"
                        android:text="3"
                        android:inputType="number"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quota (Seats)"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etDepartureQuota"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 34"
                        android:text="34"
                        android:textColor="@color/black"
                        android:inputType="number"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Return Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return Slots (After Event)"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hours After"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etReturnHoursAfter"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 3"
                        android:textColor="@color/black"
                        android:text="3"
                        android:inputType="number"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quota (Seats)"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etReturnQuota"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., 34"
                        android:text="34"
                        android:textColor="@color/black"
                        android:inputType="number"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Slot Interval -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slot Interval"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etSlotInterval"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Minutes between slots"
                    android:text="60"
                    android:textColor="@color/black"
                    android:inputType="number"
                    android:background="@drawable/edittext_border"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="minutes"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"/>

            </LinearLayout>

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:background="#F0F8FF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ How Time Slots Work"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0033A0"
                        android:background="@color/white"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Departure slots will be generated BEFORE event start time"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Return slots will be generated AFTER event end time"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Slots are generated at the interval you set"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="CANCEL"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    android:backgroundTint="#757575"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateEvent"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="SAVE"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    android:backgroundTint="#0033A0"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>